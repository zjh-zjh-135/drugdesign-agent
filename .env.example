# DrugDesign Agent 环境变量配置
# 复制此文件为 .env 并填入实际值

# ============================================================
# 必填：KIMI API Key（AI 聊天功能必需）
# 获取方式：https://platform.moonshot.cn/ 注册并创建 API Key
# ============================================================
KIMI_API_KEY=sk-你的KIMI_API_KEY

# ============================================================
# 可选：CORS 来源白名单（前端地址，多个用逗号分隔）
# 默认只允许本地开发环境
# ============================================================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================================
# 可选：Flask Secret Key（用于 Session/Cookie 签名）
# 生产环境必须设置！可使用命令生成：python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================
FLASK_SECRET_KEY=changeme-production-secret-key

# ============================================================
# 可选：环境模式（development / production）
# ============================================================
FLASK_ENV=development

# ============================================================
# 可选：后端端口
# ============================================================
FLASK_PORT=5000
